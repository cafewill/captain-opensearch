<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="OPENSEARCH_WEB" class="com.cube.opensearch.OpenSearchAppender">
        <url>${opensearch.url}</url>
        <index>${opensearch.index}</index>
        <username>${opensearch.username:-}</username>
        <password>${opensearch.password:-}</password>
        <app>${opensearch.app:${spring.application.name:-app}}</app>
        <env>${opensearch.env:${spring.profiles.active:-default}}</env>
        <instanceId>${opensearch.instance-id:-}</instanceId>
        <maxBatchBytes>${opensearch.max-batch-bytes:-262144}</maxBatchBytes>
        <maxBatchSize>${opensearch.max-batch-size:-200}</maxBatchSize>
        <maxMessageSize>${opensearch.max-message-size:-32768}</maxMessageSize>
        <flushIntervalSeconds>${opensearch.flush-interval-seconds:-3}</flushIntervalSeconds>
        <queueSize>${opensearch.queue-size:-10000}</queueSize>
        <connectTimeoutMillis>${opensearch.connect-timeout-millis:-3000}</connectTimeoutMillis>
        <readTimeoutMillis>${opensearch.read-timeout-millis:-5000}</readTimeoutMillis>
        <retryInitialDelayMillis>${opensearch.retry-initial-delay-millis:-500}</retryInitialDelayMillis>
        <retryMaxDelayMillis>${opensearch.retry-max-delay-millis:-10000}</retryMaxDelayMillis>
        <maxRetries>${opensearch.max-retries:-3}</maxRetries>
        <retryPartialFailures>${opensearch.retry-partial-failures:-true}</retryPartialFailures>
        <trustAllSsl>${opensearch.trust-all-ssl:-true}</trustAllSsl>
        <deadLetterLoggerName>${opensearch.dead-letter-logger-name:-com.cube.opensearch.deadletter}</deadLetterLoggerName>
        <operation>${opensearch.operation:-create}</operation>
        <timestampZone>${opensearch.timestamp-zone:-UTC}</timestampZone>
        <includeMdc>${opensearch.include-mdc:-true}</includeMdc>
        <includeKvp>${opensearch.include-kvp:-true}</includeKvp>
        <errorsToStderr>${opensearch.errors-to-stderr:-true}</errorsToStderr>

        <headers>
            <header>
                <name>Content-Type</name>
                <value>application/x-ndjson</value>
            </header>
        </headers>

        <properties>
            <esProperty>
                <name>stack_trace</name>
                <value>%ex{full}</value>
                <allowEmpty>false</allowEmpty>
            </esProperty>
        </properties>
    </appender>

    <appender name="OPENSEARCH_JOB" class="com.cube.opensearch.OpenSearchJobAppender">
        <url>${opensearch.url}</url>
        <index>${opensearch.index}</index>
        <username>${opensearch.username:-}</username>
        <password>${opensearch.password:-}</password>
        <app>${opensearch.app:${spring.application.name:-app}}</app>
        <env>${opensearch.env:${spring.profiles.active:-default}}</env>
        <instanceId>${opensearch.instance-id:-}</instanceId>
        <maxBatchBytes>${opensearch.max-batch-bytes:-262144}</maxBatchBytes>
        <maxBatchSize>${opensearch.max-batch-size:-200}</maxBatchSize>
        <maxMessageSize>${opensearch.max-message-size:-32768}</maxMessageSize>
        <flushIntervalSeconds>${opensearch.flush-interval-seconds:-3}</flushIntervalSeconds>
        <queueSize>${opensearch.queue-size:-10000}</queueSize>
        <connectTimeoutMillis>${opensearch.connect-timeout-millis:-3000}</connectTimeoutMillis>
        <readTimeoutMillis>${opensearch.read-timeout-millis:-5000}</readTimeoutMillis>
        <retryInitialDelayMillis>${opensearch.retry-initial-delay-millis:-500}</retryInitialDelayMillis>
        <retryMaxDelayMillis>${opensearch.retry-max-delay-millis:-10000}</retryMaxDelayMillis>
        <maxRetries>${opensearch.max-retries:-3}</maxRetries>
        <retryPartialFailures>${opensearch.retry-partial-failures:-true}</retryPartialFailures>
        <trustAllSsl>${opensearch.trust-all-ssl:-true}</trustAllSsl>
        <deadLetterLoggerName>${opensearch.dead-letter-logger-name:-com.cube.opensearch.deadletter}</deadLetterLoggerName>
        <operation>${opensearch.operation:-create}</operation>
        <timestampZone>${opensearch.timestamp-zone:-UTC}</timestampZone>
        <includeMdc>${opensearch.include-mdc:-true}</includeMdc>
        <includeKvp>${opensearch.include-kvp:-true}</includeKvp>
        <errorsToStderr>${opensearch.errors-to-stderr:-true}</errorsToStderr>

        <headers>
            <header>
                <name>Content-Type</name>
                <value>application/x-ndjson</value>
            </header>
        </headers>

        <properties>
            <esProperty>
                <name>stack_trace</name>
                <value>%ex{full}</value>
                <allowEmpty>false</allowEmpty>
            </esProperty>
        </properties>
    </appender>

    <root level="INFO">
        <appender-ref ref="OPENSEARCH_WEB"/>
        <appender-ref ref="OPENSEARCH_JOB"/>
    </root>
</configuration>
