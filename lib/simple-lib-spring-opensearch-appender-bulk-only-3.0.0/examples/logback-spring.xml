<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── 1. 기본 콘솔 출력 ── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── 2. 표준 OpenSearch Appender ── -->
    <appender name="OPENSEARCH" class="com.cube.opensearch.OpenSearchAppender">
        <!-- 필수 -->
        <url>${opensearch.url}</url>
        <index>${opensearch.index}</index>

        <!-- 인증 (Basic 인증 사용 시) -->
        <authentication class="com.cube.opensearch.OpenSearchBasicAuthentication">
            <username>${opensearch.username:-admin}</username>
            <password>${opensearch.password:-admin}</password>
        </authentication>

        <!-- SSL: 내부망 자가 서명 인증서 허용 (추가 파라미터) -->
        <trustAllSsl>${opensearch.trust-all-ssl:-true}</trustAllSsl>

        <!-- Writer thread: false면 logback-elasticsearch처럼 이벤트 발생 시 기동 후 idle 시 종료, true면 daemon thread 1개 유지 -->
        <persistentWriterThread>${opensearch.persistent-writer-thread:-false}</persistentWriterThread>

        <!-- 로그 포함 옵션 -->
        <includeMdc>true</includeMdc>
        <includeKvp>false</includeKvp>
        <includeCallerData>false</includeCallerData>
        <rawJsonMessage>false</rawJsonMessage>

        <!-- 3.0.0: autoStackTraceLevel - ERROR 이상이면 예외 없어도 스택트레이스 자동 첨부 -->
        <autoStackTraceLevel>ERROR</autoStackTraceLevel>

        <!-- 전송 튜닝 -->
        <sleepTime>250</sleepTime>
        <maxBatchSize>-1</maxBatchSize>
        <maxMessageSize>-1</maxMessageSize>
        <maxQueueSize>104857600</maxQueueSize>
        <connectTimeout>30000</connectTimeout>
        <readTimeout>30000</readTimeout>

        <!-- 재시도 -->
        <maxRetries>3</maxRetries>

        <!-- 벌크 작업 방식 (bulk-only: index / create) -->
        <operation>create</operation>

        <!-- 타임스탬프 포맷 (JVM 기본 타임존 사용, Asia/Seoul 예: yyyy-MM-dd'T'HH:mm:ss.SSSXXX) -->
        <!-- <timestampFormat>yyyy-MM-dd'T'HH:mm:ss.SSSXXX</timestampFormat> -->

        <!-- 커스텀 고정 프로퍼티 (PatternLayout 표현식 사용 가능) -->
        <properties>
            <property>
                <name>service_type</name>
                <value>batch-job</value>
            </property>
            <property>
                <name>log_version</name>
                <value>3.0.0</value>
            </property>
        </properties>

        <!-- 커스텀 헤더 (선택) -->
        <!--
        <headers>
            <header>
                <name>X-Custom-Header</name>
                <value>my-value</value>
            </header>
        </headers>
        -->
    </appender>

    <!-- ── 3. 3.0.0 신규: StructuredArgsOpenSearchAppender ── -->
    <!--
        logstash-logback-encoder 의 StructuredArguments.keyValue() 를 OpenSearch 필드로 직렬화.
        클래스패스에 net.logstash.logback:logstash-logback-encoder 가 있어야 동작하며,
        없으면 StructuredArgs 필드만 무시되고 나머지 로그는 정상 전송된다.

        사용 예:
          log.info("order processed", StructuredArguments.keyValue("orderId", 12345));
          log.info("user action", StructuredArguments.keyValue("userId", "abc"), StructuredArguments.keyValue("action", "login"));
    -->
    <!--
    <appender name="OPENSEARCH_STRUCTURED" class="com.cube.opensearch.StructuredArgsOpenSearchAppender">
        <url>${opensearch.url}</url>
        <index>${opensearch.index}</index>
        <authentication class="com.cube.opensearch.OpenSearchBasicAuthentication">
            <username>${opensearch.username:-admin}</username>
            <password>${opensearch.password:-admin}</password>
        </authentication>
        <trustAllSsl>${opensearch.trust-all-ssl:-true}</trustAllSsl>
        <persistentWriterThread>${opensearch.persistent-writer-thread:-false}</persistentWriterThread>
        <keyPrefix>arg_</keyPrefix>
        <objectSerialization>true</objectSerialization>
        <autoStackTraceLevel>ERROR</autoStackTraceLevel>
    </appender>
    -->

    <!-- ── 4. 루트 로거 ── -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="OPENSEARCH"/>
    </root>

</configuration>
